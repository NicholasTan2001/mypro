{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_CONNECTION_STRING"
  },
  "JwtSettings": {
    "Secret": "your-super-secret-key",
    "Issuer": "MyProfile",
    "Audience": "MyProfileUsers",
    "ExpirationMinutes": 1440
  },
  "AllowedHosts": "*"
}